# env.template — WxCC Queue Scroll Widget
#
# This file documents the four values required to run the <queue-scroll> widget
# in standalone/local testing mode (outside the Webex Contact Center Agent Desktop).
#
# In production (embedded in the Agent Desktop), these values are injected
# automatically by the desktop runtime via $STORE.* property bindings in the
# desktop layout JSON — no manual configuration is needed.
#
# For LOCAL TESTING: copy these values into the corresponding attributes on the
# <queue-scroll> tag in src/index.html before running `npm run dev`.
#
# HOW TO OBTAIN EACH VALUE:
# ---------------------------------------------------------------------------

# ORG_ID
# Your Webex Contact Center organization ID.
# Find it in Control Hub → Account → Organization ID.
ORG_ID=

# AGENT_ID
# The database ID of the agent you are testing with (not the email address).
# Find it in Control Hub → Contact Center → Users, or via the WxCC REST API:
#   GET https://api.wxcc-us1.cisco.com/organization/{orgId}/user
# Maps to $STORE.agent.agentDbId in the Agent Desktop.
AGENT_ID=

# TEAM_ID
# The ID of the team the agent will be logged into during testing.
# Find it in Control Hub → Contact Center → Teams, or via the WxCC REST API:
#   GET https://api.wxcc-us1.cisco.com/organization/{orgId}/team
# Maps to $STORE.agent.teamId in the Agent Desktop.
TEAM_ID=

# ACCESS_TOKEN
# A valid Webex Contact Center access token for the test agent.
# Generate a temporary developer token (12-hour expiry) from the Webex Developer Portal:
#   https://developer.webex.com
# In production, the Agent Desktop supplies this automatically via $STORE.auth.accessToken.
# WARNING: Never commit a real token to source control.
ACCESS_TOKEN=

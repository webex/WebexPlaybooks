# Copy to .env in this directory (playbooks/docusign-finesse-int/src/). Do not commit .env.

# --- Webex OAuth (integration app) ---
REFRESH_TOKEN=
CLIENT_ID=
CLIENT_SECRET=
# REST API base for Meetings, guests, and xAPI (default shown)
WEBEX_API_URL=https://webexapis.com/v1

# --- Cisco Finesse Task Routing ---
# POST endpoint that accepts the sample XML task body (your environment URL)
FINESSE_URL=
# Optional: full Cookie header value if your Finesse deployment requires session auth
# Example: JSESSIONID=your-session-id
FINESSE_SESSION_COOKIE=
# Set to true only for lab Finesse with self-signed TLS (disables TLS verification)
FINESSE_ALLOW_INSECURE_TLS=

# --- DocuSign (JWT grant) ---
DOCUSIGN_CLIENT_ID=
DOCUSIGN_USER_ID=
DOCUSIGN_PRIVATE_KEY_PATH=
DOCUSIGN_OAUTH_BASE_PATH=account-d.docusign.com
DOCUSIGN_BASE_PATH=https://demo.docusign.net/restapi
DOCUSIGN_API_ACCOUNT_ID=

# --- App URL (must be reachable by DocuSign for webhooks; use ngrok for local dev) ---
BASE_URL=

# --- Server ---
PORT=3000

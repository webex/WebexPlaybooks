# env.template — Second Ringer Header Widget
#
# This widget runs entirely in the browser inside Webex Agent Desktop.
# There are NO runtime secrets, API keys, or server credentials required.
#
# The only "configuration" needed is a hosting URL — the base URL where
# you publish the built dist/ folder. This is used in two places:
#
#   1. The desktop layout JSON (src/second-ringer_Layout.json):
#      Set the `src` field under headerActions to:
#        <WIDGET_HOST_URL>/index.js
#
#   2. Inside src/second-ringer.ts (line ~105), the <audio> src attribute
#      references the ring.mp3 URL. Update this to:
#        <WIDGET_HOST_URL>/ring.mp3
#      before running `npm run build` so agents load audio from your host.
#
# ---------------------------------------------------------------------------

# Base URL where dist/index.js and dist/ring.mp3 will be publicly accessible.
# Must be HTTPS. No trailing slash.
# Example: https://your-org.github.io/second-ringer/dist
# Example: https://cdn.example.com/widgets/second-ringer
WIDGET_HOST_URL=https://your-host.example.com/second-ringer

# env.template — Configuration reference for the BYOVA Dialogflow CX Gateway
#
# This gateway is configured primarily through config/config.yaml, not .env files.
# Use this file as a reference for the values you need to supply.
#
# For production deployments, store secrets using a secrets manager (e.g.,
# Google Secret Manager, AWS Secrets Manager, Vault) rather than hardcoding
# them in config.yaml or environment variables.
#
# See docs/upstream-overview.md for full auth setup instructions.

# =============================================================================
# WEBEX CONTACT CENTER — BYOVA Setup
# =============================================================================

# Your WxCC org ID (found in Webex Control Hub)
# WXCC_ORG_ID=your-org-id

# The gRPC endpoint WxCC will connect to (host:port)
# Must be publicly reachable; use a stable hostname or IP
# GATEWAY_GRPC_ENDPOINT=your-server-hostname:50051

# =============================================================================
# GOOGLE CLOUD — Required for Dialogflow CX connector
# =============================================================================

# Google Cloud project that hosts your Dialogflow CX agent
# GOOGLE_PROJECT_ID=your-gcp-project-id

# Dialogflow CX agent ID (from Agent Settings in Dialogflow CX console)
# DIALOGFLOW_AGENT_ID=your-agent-id

# Dialogflow CX agent location (e.g. global, us-central1, europe-west1)
# DIALOGFLOW_LOCATION=global

# =============================================================================
# AUTHENTICATION — Choose ONE of the following methods
# =============================================================================
# Set the corresponding values in config/config.yaml, not as env vars.
# See docs/upstream-overview.md for detailed setup steps per method.

# --- Option A: Application Default Credentials (recommended for production) ---
# No variables needed here. Run:
#   gcloud auth application-default login
# or attach a GCP service account to your Compute Engine / GKE workload.

# --- Option B: Service Account Key File ---
# Store the path to your downloaded JSON key file:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa-key.json
#
# In config.yaml:
#   service_account_key: "/path/to/sa-key.json"

# --- Option C: OAuth 2.0 User Credentials (development only) ---
# Create a Desktop app OAuth client ID in Google Cloud Console, then:
# OAUTH_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
# OAUTH_CLIENT_SECRET=YOUR_CLIENT_SECRET
#
# In config.yaml:
#   oauth_client_id: "YOUR_CLIENT_ID.apps.googleusercontent.com"
#   oauth_client_secret: "YOUR_CLIENT_SECRET"
#   oauth_token_file: "dialogflow_oauth_token.pickle"
#
# Note: add *.pickle to .gitignore — never commit OAuth token files.

# =============================================================================
# AWS (Optional) — Required only if using the AWS Lex v2 connector
# =============================================================================

# AWS region where your Lex bot is deployed
# AWS_DEFAULT_REGION=us-east-1

# AWS credentials (if not using IAM role or ~/.aws/credentials)
# AWS_ACCESS_KEY_ID=your-access-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Lex bot alias ID (default: TSTALIASID for test aliases)
# LEX_BOT_ALIAS_ID=TSTALIASID

# =============================================================================
# GATEWAY RUNTIME (Optional overrides)
# =============================================================================

# gRPC server port (default: 50051)
# GATEWAY_PORT=50051

# Monitoring dashboard port (default: 8080)
# MONITORING_PORT=8080

# Python logging level for the gateway (DEBUG | INFO | WARNING | ERROR)
# GATEWAY_LOG_LEVEL=INFO

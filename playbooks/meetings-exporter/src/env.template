# Webex
# Create an app at https://developer.webex.com and use OAuth2 or a personal access token.
# Use individual meeting instance IDs (not series) for summaries, recordings, and transcripts.
WEBEX_ACCESS_TOKEN=
# Optional for OAuth2 flow:
# WEBEX_CLIENT_ID=
# WEBEX_CLIENT_SECRET=

# Export backend: google_drive, or local (write to LOCAL_EXPORT_PATH or use CLI --output-dir)
EXPORT_BACKEND=local
# When EXPORT_BACKEND=local, directory to write meeting assets (or use CLI --output-dir)
# LOCAL_EXPORT_PATH=/path/to/exports

# Google Drive (when EXPORT_BACKEND=google_drive)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Enable Google Drive API. Download OAuth client JSON and set path here.
GOOGLE_CREDENTIALS_FILE=
GOOGLE_TOKEN_FILE=token.json
# Optional: root folder ID in Drive; meeting folders will be created under it.
# GOOGLE_DRIVE_FOLDER_ID=

# Webhook server (optional)
# WEBEX_WEBHOOK_SECRET=  # Optional: verify X-Spark-Signature

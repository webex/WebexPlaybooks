# env.template — WxCC AI Agent Scripted Package Tracking
#
# This file lists the org-specific values you must substitute in
# ai_agent_scripted_track_package.json before importing the flow into your
# Webex Contact Center org.
#
# The JSON shipped in this repo was exported from a Cisco sample org.
# None of the UUIDs below are valid outside that org. Importing without
# replacing them will cause validation errors in Flow Designer.
#
# HOW TO USE:
#   1. Locate each key in ai_agent_scripted_track_package.json using your
#      editor's Find & Replace (Ctrl+H / Cmd+H).
#   2. Replace the sample value with your org's value.
#   3. Save and import the updated file into Flow Designer.
#
# ─────────────────────────────────────────────────────────────────────

# ORG_ID
# Your Webex org's unique identifier.
# Find it in Control Hub → Account → Organization ID.
# JSON field: orgId (top-level)
# Sample value in JSON: dee8d6d3-569b-4eb1-9c52-38304a3c0812
ORG_ID=<your-org-id>

# VIRTUAL_AGENT_ID
# The ID of the scripted AI agent you created in Webex AI Agent Studio.
# Find it in AI Agent Studio on the agent's detail page, or via the
# Webex Contact Center API: GET /v1/ai-agents
# JSON field: virtualAgentId (inside VirtualAgentV2_anz activity properties)
# Sample value in JSON: 679381b485a65d0086652f86
VIRTUAL_AGENT_ID=<your-virtual-agent-id>

# VIRTUAL_AGENT_NAME (display only — update the _name fields for UI clarity)
# The display name of your AI agent as it will appear in Flow Designer.
# JSON fields: virtualAgentId_name, virtualAgentId:name
# Sample value in JSON: Track Package Scripted(Track_package-scripted-pLGwCv6E)
VIRTUAL_AGENT_NAME=<YourAgentName(YourAgentName-UniqueId)>

# TRACK_PACKAGE_QUEUE_ID
# The UUID of the queue for callers whose last active intent was "Track Package".
# This queue is used by QueueContact_abk (the Case activity "Track Package" branch).
# Find it in Control Hub → Customer Experience → Queues → select your queue → copy the ID from the URL.
# JSON field: destination (inside QueueContact_abk activity properties)
# Sample value in JSON: 8a9e96e9-4b59-478b-9f64-76a29fa1bb58
TRACK_PACKAGE_QUEUE_ID=<your-track-package-queue-id>

# GENERAL_QUEUE_ID
# The UUID of the general escalation queue for all other intents and direct escalations.
# This queue is used by QueueContact_9hx (escalation and default Case branch).
# Find it in Control Hub → Customer Experience → Queues → select your queue → copy the ID from the URL.
# JSON field: destination (inside QueueContact_9hx activity properties)
# Sample value in JSON: ca9fd4e3-7c64-4086-9185-96b9cbde3f1e
GENERAL_QUEUE_ID=<your-general-queue-id>

# TRACK_PACKAGE_QUEUE_NAME (display only)
# The display name of the Track Package queue as it will appear in Flow Designer.
# JSON field: destination_name, destination:name (inside QueueContact_abk)
# Sample value in JSON: Queue-1
TRACK_PACKAGE_QUEUE_NAME=<your-track-package-queue-name>

# GENERAL_QUEUE_NAME (display only)
# The display name of the general escalation queue as it will appear in Flow Designer.
# JSON field: destination_name, destination:name (inside QueueContact_9hx)
# Sample value in JSON: Queue-1
GENERAL_QUEUE_NAME=<your-general-queue-name>

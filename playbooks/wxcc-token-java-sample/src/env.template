# Copy to your shell environment or IDE run configuration before starting the app.
# Never commit real client secrets.

# Required — from your Webex integration app at https://developer.webex.com/my-apps
WXCC_OAUTH_CLIENT_ID=
WXCC_OAUTH_CLIENT_SECRET=

# Optional — must match the redirect URI registered on the integration (default shown)
# WXCC_OAUTH_REDIRECT_URI=http://localhost:8080/login/oauth2/code/webexcc

# Optional — OAuth scopes (comma-separated, no spaces). Defaults match WxCC admin-style samples.
# WXCC_OAUTH_SCOPE=cjp:user,spark:people_read,cjp:config_write,cjp:config,cjp:config_read

# Optional — post-login and logout browser targets (defaults suit bundled static UI)
# WXCC_OAUTH_LOGIN_URI=/
# WXCC_OAUTH_LOGIN_SUCCESS_URI=/index.html
# WXCC_OAUTH_LOGOUT_SUCCESS_URI=/

# Optional — Webex API OAuth endpoints (override only for testing or future API changes)
# WXCC_OAUTH_AUTHORIZATION_URI=https://webexapis.com/v1/authorize
# WXCC_OAUTH_TOKEN_URI=https://webexapis.com/v1/access_token
# WXCC_OAUTH_USER_INFO_URI=https://webexapis.com/v1/people/me

# Optional — HTTP listen port
# SERVER_PORT=8080

# Copy this file to .env and fill in your values before running the server or building the widget.
# Never commit .env to version control.

# -----------------------------------------------------------------------
# PORT
# The TCP port the Express server listens on.
# Default: 5000
# -----------------------------------------------------------------------
PORT=5000

# -----------------------------------------------------------------------
# HOST_URI
# The public HTTPS base URL of your Cherry Picker server.
# This value is injected into the frontend bundle at webpack build time
# (via dotenv-webpack) and is referenced by the widget to connect to
# Socket.io and to fetch caller metadata from /callerIds.
#
# Must be publicly accessible — the WxCC Flow HTTP Request node will POST
# to this URL. Localhost will not work for the flow webhook.
#
# Example: HOST_URI="https://cherry-picker.yourcompany.com"
# -----------------------------------------------------------------------
HOST_URI=""

# env.template — Environment variables for the Webex Embedded App Lobby
#
# Copy this file to .env in the project root and fill in the values.
# NEVER commit a .env file containing real values to source control.
#
# Usage:
#   cp src/env.template .env
#   # then edit .env with your actual values

# ---------------------------------------------------------------------------
# BACKEND — Flask server (backend/.env or project root .env)
# ---------------------------------------------------------------------------

# FRONTEND_URL
#   The full HTTPS URL where the React frontend is served.
#   This is used by the backend to generate shareable lobby URLs.
#   For local development without HTTPS:
#     FRONTEND_URL=http://localhost:5173
#   For production or ngrok/local HTTPS:
#     FRONTEND_URL=https://yourdomain.com
FRONTEND_URL=http://localhost:5173

# ---------------------------------------------------------------------------
# FRONTEND — Vite React app (frontend/.env.development.local or .env.production)
# See frontend/env.development.example and frontend/env.production.example
# for the Vite-specific variable format (VITE_ prefix required).
# ---------------------------------------------------------------------------

# VITE_API_URL
#   The base URL for the Flask REST API (used by the Axios client in frontend/src/utils/api.js).
#   For local dev:    http://localhost:5000
#   For production:   https://yourdomain.com
VITE_API_URL=http://localhost:5000

# VITE_SOCKET_URL
#   The URL for the Socket.IO WebSocket connection.
#   For local dev:    http://localhost:5000
#   For production:   https://yourdomain.com
VITE_SOCKET_URL=http://localhost:5000

# ---------------------------------------------------------------------------
# WEBEX EMBEDDED APP — configured in the Webex Developer Portal
# No secrets are required at runtime for the Embedded Apps SDK.
# The SDK initializes automatically inside a Webex Meeting using the
# @webex/embedded-app-sdk package. Register your app at:
#   https://developer.webex.com/my-apps → Create New App → Embedded App
# Provide the HTTPS URL of your deployed frontend as the app URL.
# ---------------------------------------------------------------------------

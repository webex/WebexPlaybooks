# Login with Webex — Environment Variables
# Copy this file to src/.env and fill in the values.
# Never commit .env or real credentials to version control.

# Webex Integration Client ID (from developer.webex.com)
# Required for ID Token flow (openid3.html). PKCE flow uses form input.
WEBEX_CLIENT_ID=

# Optional: Port for the demo server (default 3000)
# PORT=3000

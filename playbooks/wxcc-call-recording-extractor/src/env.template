# Webex Contact Center — Call Recording Extractor (Capture API sample)
# Copy this file to .env in the same directory as pom.xml and export variables
# before running Maven, e.g. `set -a && source .env && set +a` (bash) or use
# your IDE run configuration to inject env vars. Spring Boot reads these at runtime.

# --- Required: WxCC integration (developer.webex.com — Create an integration) ---
CLIENT_ID=
CLIENT_SECRET=
# Must match the redirect URI registered on the integration
REDIRECT_URI=http://localhost:8080

# --- Required: WxCC API cluster (must match your org region) ---
# Examples: https://api.wxcc-us1.cisco.com , https://api.wxcc-eu1.cisco.com , ...
DATA_CENTER_URL=https://api.wxcc-us1.cisco.com

# --- Optional OAuth / API tuning ---
WXCC_OAUTH_SCOPE=cjp:config_read
OAUTH_STATE=wxcc-capture-sample
CAPTURE_URL_EXPIRATION_MINUTES=30

# --- Storage backend (one primary target; list in application.yml uses first type) ---
# WXCC_STORAGE_TARGET: localhost | fileSystemAWSS3 | fileSystemGCPCloudStorage
WXCC_STORAGE_TARGET=localhost
LOCALHOST_DATA_DIRECTORY=/tmp/wxcc-recordings

# --- If WXCC_STORAGE_TARGET=fileSystemAWSS3 ---
AWS_S3_USER_LABEL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=

# --- If WXCC_STORAGE_TARGET=fileSystemGCPCloudStorage ---
GCP_PROJECT_ID=
GCP_STORAGE_BUCKET=
GCP_STORAGE_REGION=
# Path to service account JSON (standard Google client library env var)
GOOGLE_APPLICATION_CREDENTIALS=

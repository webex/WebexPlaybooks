# env.template — Webex Finesse Agent Presence Sync
#
# Copy this file to .env and fill in all required values before starting the server.
# Never commit your .env file to source control.
#
# Usage:
#   cp env.template .env
#   # Edit .env with your values
#   npm start          (or: docker run --env-file .env ...)

# ─────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────

# TCP port the Node.js server listens on.
# Default is 5000 if not set.
PORT=5000

# ─────────────────────────────────────────────────────────────
# Webex
# ─────────────────────────────────────────────────────────────

# Webex Bot access token.
# Create a bot at https://developer.webex.com/my-apps and copy the token shown
# immediately after creation — it is only displayed once.
# Keep this value secret; it grants presence subscription access to your Webex org.
WEBEX_ACCESS_TOKEN=

# Email domain shared by all monitored agents.
# Example: if agents have emails like jsmith@acme.com, set this to acme.com
WEBEX_DOMAIN=

# ─────────────────────────────────────────────────────────────
# Finesse — general
# ─────────────────────────────────────────────────────────────

# Operating mode.
# true  = Gadget mode (recommended): server pushes presence via Socket.io to the
#         Finesse gadget running in the agent's browser. Supports specific NOT_READY
#         reason codes ("Webex DND", "Webex Meeting", "Webex Call", "Webex Unavailable").
# false = Server mode: server calls the Finesse REST API directly using
#         FINESSE_SUPERVISOR_TOKEN. Limited to READY and generic NOT_READY only.
GADGET_MODE=true

# Comma-separated list of Finesse agent login names to monitor.
# These must match the loginName field in the Finesse user directory exactly.
# The agent's Webex email is derived as: <loginName>@<WEBEX_DOMAIN>
# Example: FINESSE_USERS=jsmith,awilliams,mbrown
FINESSE_USERS=

# Base URL of your Cisco Finesse server (no trailing slash).
# Example: https://finesse.acme.com
# The server connects here for all Finesse REST API calls (/finesse/api/...).
FINESSE_BASE_URL=

# The Finesse server origin allowed to connect to the Socket.io server (gadget mode).
# Set this to the base URL of your Finesse server so the browser gadget can connect.
# Example: https://finesse.acme.com
# This is used for the Socket.io CORS origin configuration.
FINESSE_ORIGIN=

# Basic Auth token for a Finesse administrator account.
# Used to: (1) read the agent user directory on startup, (2) read current agent
# state in server mode.
# Generate with: echo -n "admin_username:password" | base64
FINESSE_ADMIN_TOKEN=

# Basic Auth token for a Finesse supervisor account.
# Required only in server mode (GADGET_MODE=false).
# Used to set agent state via PUT /finesse/api/User/:id.
# Generate with: echo -n "supervisor_username:password" | base64
FINESSE_SUPERVISOR_TOKEN=

# Whether to validate the Finesse server's TLS certificate.
# Set to false only for lab/development environments with self-signed certificates.
# Default: true
FINESSE_REJECT_UNAUTHORIZED=true

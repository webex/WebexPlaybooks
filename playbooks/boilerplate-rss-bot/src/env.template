# Copy to .env in this directory (or export in your shell). Never commit .env.

# --- Required ---
# Webex bot access token (Bot created at developer.webex.com).
TOKEN=

# Target Webex space (room) ID. The bot must be a member of this space.
FEED_ROOM_ID=

# Public RSS or Atom feed URL (HTTPS recommended).
RSS_FEED_URL=

# --- Optional polling ---
# Seconds between feed checks (default 5).
# RSS_INTERVAL=5

# --- HTTP client ---
# HTTP_TIMEOUT=60000

# --- Logging ---
# CONSOLE_LEVEL=info
# APP_NAME=rss-service

# Syslog (optional)
# SYSLOG_ENABLED=false
# SYSLOG_HOST=syslog
# SYSLOG_PORT=514
# SYSLOG_PROTOCOL=udp4
# SYSLOG_SOURCE=localhost

# Grafana Loki (optional)
# LOKI_ENABLED=false
# LOKI_HOST=http://loki:3100

# Corporate proxy (optional; enables global-agent when set)
# GLOBAL_AGENT_HTTP_PROXY=http://proxy.example.com:8080
# GLOBAL_AGENT_NO_PROXY=localhost,127.0.0.1
# NODE_EXTRA_CA_CERTS=/path/to/extra-ca.pem

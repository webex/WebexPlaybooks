# Copy to .env in this directory (do not commit .env).
# Webex Contact Center — graphql wallboard sample

# "dev" = use DEV_TOKEN from env. "production" = token from MongoDB (requires DB + setup).
ENVIRONMENT=dev

# Your WxCC / Webex org ID (Control Hub / developer portal).
ORG_ID=

# Personal access token with admin/API access; obtain from developer.webex.com
# (sign in as a WxCC admin). Short-lived — refresh when calls fail with 401.
DEV_TOKEN=

# Basic-auth user/password for this app’s /dev-token route. The server compares
# incoming Basic credentials to these values; wallboard code calls /dev-token
# using the same NAME and PASS. Set any non-empty values and keep them in sync.
NAME=devuser
PASS=devpass

# Base URL of this app (used by token helpers to call /dev-token and related routes).
# Must match how you open the UI (host and port).
URL=http://localhost:3000

# Rolling window (days) for wallboard GraphQL task(...) time range and chart legends.
# WALLBOARD_LOOKBACK_DAYS=7

# WxCC API cluster base URL, no trailing slash. Must match your tenant region.
# Examples: https://api.wxcc-us1.cisco.com , https://api.wxcc-eu1.cisco.com
WXCC_API_BASE=https://api.wxcc-us1.cisco.com

# HTTP listen port (optional; defaults to 3000).
# PORT=3000

# --- Optional: MongoDB + basic-auth routes (upstream "production" token flow) ---

# DB=mongodb://...

# Basic auth for /token, /add, /update, /refreshToken, /dev-token
# NAME=
# PASS=

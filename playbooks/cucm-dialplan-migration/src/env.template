# env.template — Required environment variables for the Cisco UCM Dial Plan playbook
#
# Copy this file to .env in the src/ directory and fill in all values.
# NEVER commit .env to source control — it contains sensitive credentials.
#
# Usage:
#   cp env.template .env
#   # then edit .env with your actual values

# =============================================================================
# Webex OAuth Integration credentials
# Obtain these from developer.webex.com/my-apps after creating an Integration.
# Set Redirect URI to: http://localhost:6001/redirect
# =============================================================================

# Client ID from your Webex Integration
TOKEN_INTEGRATION_CLIENT_ID=<your-webex-integration-client-id>

# Client Secret from your Webex Integration
TOKEN_INTEGRATION_CLIENT_SECRET=<your-webex-integration-client-secret>

# Space-separated list of OAuth scopes required by the scripts
TOKEN_INTEGRATION_CLIENT_SCOPES=spark-admin:telephony_config_write spark-admin:telephony_config_read

# =============================================================================
# Cisco UCM AXL API credentials
# The AXL account must have the "Standard AXL API Access" role in UCM.
# =============================================================================

# UCM hostname or IP address (port 8443 is used automatically if not specified)
AXL_HOST=<ucm-hostname-or-ip>

# UCM AXL API username
AXL_USER=<ucm-axl-username>

# UCM AXL API password
AXL_PASSWORD=<ucm-axl-password>

# Copy this file to .env in this directory (src/). Do not commit .env.
#
# Webex OAuth client (Integration app) — used for browser login and refresh via
# POST https://webexapis.com/v1/access_token
CLIENT_ID=<your-client-id-here>
CLIENT_SECRET=<your-client-secret-here>

# Redirect URI must match exactly what you register on the Integration and what Webex redirects to.
# Example for local dev: http://localhost:5000/auth/webex/callback (same path as GET /auth/webex/callback).
REDIRECT_URI=http://localhost:5000/auth/webex/callback

# Space-separated OAuth scopes your Integration lists (URL-encoded automatically on /login).
# See https://developer.webex.com — align with WxCC / platform APIs you need.
OAUTH_SCOPES=spark:all

# Your Webex org ID — must match the signing-in user’s org. Used when persisting tokens from
# authorization_code exchange (JWT access tokens do not use the legacy composite format).
ORG_ID=<your-org-id-here>

# Optional: WxCC cluster id when access_token is a plain JWT (not the legacy access_cluster_org form).
# If unset, the sample stores cluster_id as "unknown"; adjust per your tenant/API docs if needed.
# CLUSTER_ID=<your-cluster-id-here>

# Optional: initial refresh token if you are not using browser /login yet. The scheduler prefers
# refresh_token stored in SQLite after OAuth; falls back to this env var if the DB has none.
REFRESH_TOKEN=<your-refresh-token-here>

# Optional seed values (upstream README); the running app primarily uses DB + scheduler refresh.
ACCESS_TOKEN=<your-access-token-here>

# Shared secret Flow Designer (or your HTTP client) must send as header x-api-phrase when calling GET /api/token
PASSPHRASE=<your-random-passphrase-here>

# Expected caller identity headers (must match what Flow Designer or your client sends)
FROM=admin@webexcc.com

# Expected source IP for GET /api/token (Flow Designer egress per your datacenter — see Webex security docs)
SOURCE_IP=127.0.0.1

# HTTP server bind
PORT=5000
# HOST=0.0.0.0

# Optional: Sequelize SQLite path (relative to process cwd, usually this src/ directory)
# DB_DIALECT=sqlite
# DB_STORAGE=./db/db.sqlite

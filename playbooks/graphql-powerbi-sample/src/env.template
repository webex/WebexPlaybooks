# Copy to .env in this directory (or export in your shell) before running the app.
# Never commit real credentials.

# Webex integration (https://developer.webex.com/my-apps)
CLIENT_ID=
CLIENT_SECRET=

# Must match the redirect URI registered on the integration (default matches sample).
REDIRECT_URI=http://localhost:8080

# WxCC OAuth scope for this sample (default is typical for config/read flows).
WXCC_OAUTH_SCOPE=cjp:config_read

# Opaque value sent through the OAuth state parameter.
OAUTH_STATE=graphql-powerbi-sample

# WxCC API base URL for your data center (examples below).
DATA_CENTER_URL=https://api.wxcc-us1.cisco.com
# DATA_CENTER_URL=https://api.wxcc-anz1.cisco.com
# DATA_CENTER_URL=https://api.wxcc-ca1.cisco.com
# DATA_CENTER_URL=https://api.wxcc-eu1.cisco.com
# DATA_CENTER_URL=https://api.wxcc-eu2.cisco.com
# DATA_CENTER_URL=https://api.wxcc-jp1.cisco.com

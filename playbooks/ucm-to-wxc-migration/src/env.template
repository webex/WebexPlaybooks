# env.template — Copy this file to .env and fill in all values before running.
#
# Required by main.py, export_to_csv.py, and read_gdpr.py.
# Never commit .env to source control.

# -----------------------------------------------------------------------------
# UCM AXL Connection
# -----------------------------------------------------------------------------

# Hostname or IP address of the Cisco UCM publisher node (AXL endpoint).
# The AXL service must be activated on this node (System > Cisco Unified CM).
AXL_HOST=

# Username for AXL authentication. The account must have the
# "Standard AXL API Access" role in UCM.
AXL_USER=

# Password for the AXL user above.
AXL_PASSWORD=

# -----------------------------------------------------------------------------
# Webex Calling Authentication
# -----------------------------------------------------------------------------

# Personal access token from https://developer.webex.com/docs/api/getting-started
# Log in as a Webex org administrator, click your avatar, and copy the token.
# NOTE: This token expires in approximately 12 hours. Re-obtain it if it expires
# during a long migration run.
WEBEX_ACCESS_TOKEN=

# -----------------------------------------------------------------------------
# Test Email Address Construction (main.py only)
# -----------------------------------------------------------------------------

# Your Gmail address (without @gmail.com). Used to construct synthetic plus-addressed
# email addresses for test provisioning (e.g. yourname+userA@gmail.com).
# For production use, replace the webex_email() function in main.py with logic
# that returns real UCM user email addresses.
GMAIL_ID=

# Copy to .env in this directory (see README). Never commit .env.

# HTTP server
PORT=5000
# Optional bind address (default 0.0.0.0)
# HOST=0.0.0.0

# Webex integration (OAuth) — from developer.webex.com or WxCC developer portal
CLIENT_ID=
CLIENT_SECRET=
REDIRECT_URI=http://localhost:5000/auth/webex/callback

# Webex Contact Center organization ID (used in captures query)
ORG_ID=

# WxCC API base for your cluster (no trailing slash). US1 default shown.
WXCC_API_BASE=https://api.wxcc-us1.cisco.com

# Directory to write downloaded recordings (created if missing)
FILE_PATH=./recordings

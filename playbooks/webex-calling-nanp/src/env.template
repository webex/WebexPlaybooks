# Copy to .env in this directory (or export variables) before running local_tp.py.
# Never commit real credentials.

# Option A: short-lived access token for Webex Calling APIs (see Webex developer docs).
WEBEX_TOKEN=

# Option B: service app (preferred for automation) — used if WEBEX_TOKEN is unset or expired cache logic applies.
SERVICE_APP_CLIENT_ID=
SERVICE_APP_CLIENT_SECRET=
SERVICE_APP_REFRESH_TOKEN=

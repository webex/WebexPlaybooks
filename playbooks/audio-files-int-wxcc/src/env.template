# Backend environment variables. Copy to .env in this directory (src/) or set in your environment.
# Never commit .env or real secrets.

# MongoDB connection string (required for user and audio file metadata).
MONGO_URI=mongodb+srv://YOURCLUSTER.mongodb.net/

# Port the Express backend listens on. Update frontend proxy (e.g. frontend/vite.config.js) if you change this.
PORT=5000

# Webex integration credentials (from your registered integration).
CLIENT_ID=YOUR_WXCC_CLIENT_ID
CLIENT_SECRET=YOUR_WXCC_CLIENT_SECRET

# OAuth redirect URI; must match the integration's redirect URI (e.g. http://localhost:5173/oauth).
REDIRECT_URI=http://localhost:5173/oauth

# Webex Contact Center API base URL. Defaults to US1 if unset; use your cluster's base (e.g. api.wxcc-eu1.cisco.com) if different.
# WXCC_API_BASE=https://api.wxcc-us1.cisco.com

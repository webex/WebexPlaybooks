# Copy this file to .env.local in this directory (same folder as package.json).
# Create React App only exposes variables prefixed with REACT_APP_ to the browser bundle.
# Never commit .env.local or real tokens.

# Personal or integration access token for Webex (Meetings + Teams widget). Lab/dev only:
# values are embedded in the client bundle at build/start time.
REACT_APP_WEBEX_ACCESS_TOKEN=

# Space ID for the embedded Space Widget (Teams messaging).
REACT_APP_WEBEX_SPACE_ID=

# SIP URI or meeting locator passed to webex.meetings.create() (see Webex JS SDK meetings docs).
REACT_APP_WEBEX_SIP_URL=

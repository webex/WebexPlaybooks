# Integration credentials (from Webex Developer Portal)
INT_CLIENTID=your_integration_client_id
INT_CLIENTSECRET=your_integration_client_secret

# Service App credentials
SA_CLIENTID=your_service_app_client_id
SA_CLIENTSECRET=your_service_app_client_secret

# Leave empty; filled after first OAuth flow
INT_ACCESSTOKEN=
INT_REFRESHTOKEN=

# Webex token endpoint
TOKEN_ENDPOINT=https://webexapis.com/v1/access_token

# Webhook URL (must end with /webhook; use tunnel URL for local dev, e.g. https://xxxx.ngrok.io/webhook)
TARGET_URL=https://mywebhookurl.com/webhook

# Server port (optional, default 3000)
PORT=3000

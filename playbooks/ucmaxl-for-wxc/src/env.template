# env.template — Required environment variables for ucmaxl-for-wxc
# Copy this file to .env and fill in all values.
# Never commit .env to source control.

# ── Cisco UCM AXL Connection ─────────────────────────────────────────────────

# UCM_HOST: IP address or FQDN of the UCM publisher node.
# Include a port suffix if not using the default 8443 (e.g. "192.168.1.10:8443").
UCM_HOST=

# UCM_USER: Username of an AXL-enabled account.
# The account must have the "Standard AXL API Access" role in UCM.
UCM_USER=

# UCM_PASSWORD: Password for the AXL user account above.
UCM_PASSWORD=

# UCM_VERIFY_TLS: Set to "true" to enable TLS certificate verification.
# Default is "false" (verification disabled) for lab/dev environments.
# For production, set to "true" and ensure the UCM CA certificate is trusted
# by the system's CA bundle, or pass the CA path directly in main.py.
UCM_VERIFY_TLS=false

# ── Webex Calling ─────────────────────────────────────────────────────────────

# WEBEX_ACCESS_TOKEN: Personal access token from https://developer.webex.com
# Valid for approximately 12 hours. The account must be a Webex org admin with
# access to Webex Calling configuration.
WEBEX_ACCESS_TOKEN=

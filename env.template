# Contentstack CMA (Content Management API) - for publish/discovery scripts
# Copy to .env and fill in values. Never commit .env.

# Required for fetch-contentstack-data.js and publish-playbook.js
CONTENTSTACK_MANAGEMENT_TOKEN=
CMS_API_KEY=

# Optional: override base URL (default: https://api.contentstack.io)
# CMS_BASE_URL=https://api.contentstack.io

# Optional: Contentstack stack UID for PR comment links (default: bltd14fd2a03236233f)
# Set as GitHub Secret CMS_STACK_UID if using a different stack
